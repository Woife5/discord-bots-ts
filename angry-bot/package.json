{
    "name": "@woife5/angry-bot",
    "version": "4.0.0",
    "description": "Angry Bot.",
    "type": "module",
    "license": "GPL-3.0",
    "author": "Wolfgang Schwendtbauer",
    "scripts": {
        "start": "pnpm run build && node --env-file=.env angry-bot.cjs",
        "build": "esbuild ./src/angry-bot.ts --bundle --outfile=angry-bot.cjs --minify-whitespace --minify-syntax --platform=node",
        "lint": "biome lint",
        "format": "biome format",
        "check": "biome check",
        "typecheck": "tsc --noEmit",
        "predockerize": "pnpm run lint && pnpm run typecheck && pnpm run build",
        "dockerize": "docker buildx build -t woife5/angry-bot:latest -f ./Dockerfile --platform=linux/arm64,linux/amd64 -o type=registry ."
    },
    "devDependencies": {
        "@biomejs/biome": "catalog:",
        "@types/node-cron": "^3.0.11",
        "typescript": "catalog:",
        "esbuild": "catalog:"
    },
    "dependencies": {
        "@woife5/shared": "workspace:*",
        "discord.js": "catalog:",
        "mongoose": "^9.3.3",
        "node-cron": "^4.2.1"
    }
}
