{
    "name": "@woife5/boller-bot",
    "version": "1.0.0",
    "description": "BollerBot",
    "type": "module",
    "main": "./index.js",
    "license": "GPL-3.0",
    "author": "Wolfgang Schwendtbauer",
    "scripts": {
        "start": "bun --watch src/boller-bot.ts",
        "build": "bun build ./src/boller-bot.ts --compile --drop=console.debug --outfile=bollerbot",
        "lint": "biome lint",
        "format": "biome format",
        "check": "biome check",
        "typecheck": "tsc --noEmit",
        "predockerize": "bun run check && bun run typecheck && bun run build",
        "dockerize": "docker buildx build -t woife5/boller-bot:latest -f ./Dockerfile --platform=linux/arm64,linux/amd64 -o type=registry .."
    },
    "devDependencies": {
        "@biomejs/biome": "catalog:",
        "bun-types": "catalog:",
        "typescript": "catalog:"
    },
    "dependencies": {
        "@discordjs/opus": "^0.10.0",
        "@discordjs/voice": "^0.19.0",
        "@snazzah/davey": "^0.1.9",
        "@woife5/shared": "workspace:*",
        "discord.js": "catalog:",
        "ffmpeg-static": "^5.3.0",
        "libsodium-wrappers": "^0.8.1",
        "mongodb": "^7.0.0",
        "sodium": "^3.0.2"
    }
}
